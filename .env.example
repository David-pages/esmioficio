VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local development can omit this and use window.location.origin.
# In production set it to the real public URL so auth emails never use localhost.
VITE_SITE_URL=https://esmioficio.mx

# Password gate for the /admin panel UI. This only hides the dashboard UI;
# real data protection must come from Supabase RLS policies.
VITE_ADMIN_PASSWORD=choose-a-strong-password
